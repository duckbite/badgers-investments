{
  "name": "badgers-investments",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dynamodb:smoke-write": "pnpm --filter api dynamodb:smoke-write",
    "bootstrap:user": "pnpm --filter api bootstrap:user",
    "seed:dev-wealth": "pnpm --filter api seed:dev-wealth",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean --force && rm -rf node_modules",

    "infra:bootstrap": "terraform -chdir=infra/terraform/bootstrap init -upgrade && terraform -chdir=infra/terraform/bootstrap apply",
    "infra:dev:init": "terraform -chdir=infra/terraform/envs/dev init -upgrade -backend-config=infra/terraform/envs/dev/backend.hcl",
    "infra:dev:apply": "terraform -chdir=infra/terraform/envs/dev apply",
    "infra:dev:validate": "terraform -chdir=infra/terraform/envs/dev init -backend=false -upgrade && terraform -chdir=infra/terraform/envs/dev validate",
    "infra:prod:apply": "terraform -chdir=infra/terraform/envs/prod init -upgrade && terraform -chdir=infra/terraform/envs/prod apply",
    "deploy:prod": "bash tools/prod/deploy-prod.sh",
    "smoke:prod": "bash tools/prod/smoke-test.sh",
    "prod:up": "bash tools/prod/prod-up.sh",

    "infra:fmt": "docker run --rm -v \"$PWD\":/workspace -w /workspace hashicorp/terraform:1.12.2 fmt -recursive infra/terraform",
    "infra:validate": "docker run --rm -v \"$PWD\":/workspace -w /workspace hashicorp/terraform:1.12.2 -chdir=infra/terraform/envs/prod init -backend=false -upgrade && docker run --rm -v \"$PWD\":/workspace -w /workspace hashicorp/terraform:1.12.2 -chdir=infra/terraform/envs/prod validate",
    "infra:tflint": "docker run --rm -v \"$PWD\":/workspace -v \"$PWD/.tflint.d\":/root/.tflint.d -w /workspace --entrypoint sh ghcr.io/terraform-linters/tflint:v0.55.0 -lc \"tflint --chdir=infra/terraform/envs/prod --init && tflint --chdir=infra/terraform/envs/prod\""
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
