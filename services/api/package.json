{
  "name": "api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "pretest": "pnpm run db:generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "pnpm run db:generate",
    "test:coverage": "vitest run --coverage",
    "pretest:integration": "pnpm run db:generate",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
