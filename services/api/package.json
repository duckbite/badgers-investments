{
  "name": "api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "dynamodb:smoke-write": "dotenv -e ../../.env -- tsx src/scripts/dynamodb-smoke-write.ts",
    "recommendation-queue:process": "dotenv -e ../../.env -- tsx src/scripts/process-recommendation-queue.ts",
    "recommendation-queue:watch": "bash -lc 'while true; do pnpm recommendation-queue:process; sleep 2; done'",
    "bootstrap:user": "dotenv -e ../../.env -- tsx src/scripts/put-dev-user.ts",
    "seed:dev-wealth": "dotenv -e ../../.env -- tsx src/scripts/seed-dev-wealth-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "lint": "eslint src",
    "build:lambda": "esbuild src/lambda-handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-lambda/index.cjs",
    "build:lambda:recommendation-processor": "esbuild src/lambda-recommendation-processor-handler.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist-lambda-recommendation-processor/index.mjs",
    "clean": "rm -rf dist dist-lambda dist-lambda-recommendation-processor"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@aws-sdk/client-dynamodb": "^3.1027.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1027.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "decimal.js": "^10.6.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "aws-sdk-client-mock": "^4.1.0",
    "dotenv-cli": "^7.4.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
