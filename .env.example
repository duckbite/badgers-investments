# Root env (local development)
# Copy to `.env` and adjust values.
#
# Convention:
# - All runtime environment variables live in this root `.env` file.
# - Do not create per-service `.env` files in subdirectories.

# PostgreSQL (Docker)
POSTGRES_USER=badgers
POSTGRES_PASSWORD=local
POSTGRES_DB=badgers
POSTGRES_PORT=5432

# Database URL (generic)
DATABASE_URL=postgresql://badgers:local@localhost:5432/badgers?schema=public

# API service
API_PORT=3000
API_DATABASE_URL=postgresql://badgers:local@localhost:5432/badgers?schema=public

# Frontend (SvelteKit/Vite)
PUBLIC_API_BASE_URL=http://localhost:3000

# AWS SES (email OTP)
SES_REGION=eu-west-1
SES_FROM_EMAIL=you@example.com
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# OpenAI (recommendations)
OPENAI_KEY=
