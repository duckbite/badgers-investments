# Root env (local development)
# Copy to `.env` and adjust values.
#
# Production: do not commit a prod `.env`. API secrets and peppers live in AWS Secrets Manager
# (Terraform `secrets` module JSON: COOKIE_SECRET, API_AI_SETTINGS_SECRET, API_PRIVACY_SECRET);
# the API Lambda reads them via injected environment variables. Static web build-time keys
# (e.g. PUBLIC_GOOGLE_MAPS_API_KEY) are supplied in CI from GitHub Actions secrets — see root README.
#
# Convention:
# - All runtime environment variables live in this root `.env` file.
# - Do not create per-service `.env` files in subdirectories.

# API service
API_PORT=3000
# Optional: Pino log level (default debug non-prod, info when API_NODE_ENV/production)
# API_LOG_LEVEL=info
# Browser origin(s) for the Svelte app: must match the URL in the address bar (scheme + host + port).
# Required in production. In non-production, if unset, the API reflects any Origin (local dev convenience).
# Examples:
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# DynamoDB (required for API)
API_DYNAMODB_TABLE_NAME=badgers-investments-dev
# Region: set API_DYNAMODB_REGION and/or standard AWS_REGION / AWS_DEFAULT_REGION
API_DYNAMODB_REGION=us-east-1
# Optional: custom endpoint (e.g. LocalStack). Leave unset for real AWS DynamoDB.
# API_DYNAMODB_ENDPOINT=

# Frontend (SvelteKit/Vite)
# Dev server port (Vite). If you change it, set CORS_ORIGIN to http://localhost:<WEB_PORT> when using an explicit allowlist.
WEB_PORT=5173
# Browser → API origin (baked into the static SPA at build time). If unset, Vite uses http://localhost:<API_PORT> so it stays in sync with the API listen port.
PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: Google Maps JavaScript API key for Settings → profile location (`PlaceAutocompleteElement`, Places API New).
# If the browser shows ApiTargetBlockedMapError, the key's *API restrictions* omit a required API:
#   Google Cloud Console → APIs & Services → Credentials → your key → API restrictions
#   → "Restrict key" and add at least: "Maps JavaScript API" and "Places API (New)".
# Also enable those APIs on the project: APIs & Services → Library → enable each.
# Application restrictions: HTTP referrers, e.g. http://localhost:5173/* and your production origin (include port).
# PUBLIC_GOOGLE_MAPS_API_KEY=

# Encrypts per-user AI API keys at rest in DynamoDB (any non-empty string; SHA-256 → AES-256-GCM key material)
# API_AI_SETTINGS_SECRET=change-me-in-dev

# Optional: dedicated pepper for amount-reveal PIN hashing; if unset, API_AI_SETTINGS_SECRET is used
# API_PRIVACY_SECRET=change-me-privacy

# Claude model id for recommendation AI (MVP: Anthropic only)
# API_AI_MODEL_ANTHROPIC=claude-opus-4-6

# Auth (optional overrides)
# API_SESSION_COOKIE_NAME=badgers_session
# API_SESSION_TTL_SECONDS=604800
# API_LOGIN_RATE_LIMIT_MAX=20
# API_LOGIN_RATE_LIMIT_WINDOW_MS=60000
# In production/Lambda, set API_NODE_ENV=production for Secure cookies when NODE_ENV is not production.
# Bootstrap a single user in DynamoDB (local/dev): pnpm bootstrap:user with:
# BOOTSTRAP_USERNAME=admin
# BOOTSTRAP_PASSWORD=change-me
# Same BOOTSTRAP_USERNAME (in `.env`) is used by `pnpm seed:dev-wealth` to resolve the demo portfolio owner.
