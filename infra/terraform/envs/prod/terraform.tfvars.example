aws_region = "eu-west-1"

# Leave empty to create a new Route 53 public zone for badgers.nl in this account; set to an existing zone ID to use a pre-created zone.
route53_zone_id = ""

web_domain = "investments.badgers.nl"
api_domain = "api.investments.badgers.nl"

# GitHub Actions OIDC (used for CI/CD role trust policy)
github_org  = "duckbite"
github_repo = "badgers-investments"
github_ref  = "refs/heads/main"

